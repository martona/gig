// Generated by CMake (configure_file) into build/<...>/generated/version.rc.
// The version comes from -DGIG_VERSION (scripts/build_windows.ps1 -Version, which
// the release workflow derives from the git tag); it defaults to 0.0.0.0 for plain
// local builds. Edit this template, never the generated copy.
#include <windows.h>

VS_VERSION_INFO VERSIONINFO
    FILEVERSION @GIG_VERSION_MAJOR@,@GIG_VERSION_MINOR@,@GIG_VERSION_PATCH@,@GIG_VERSION_BUILD@
    PRODUCTVERSION @GIG_VERSION_MAJOR@,@GIG_VERSION_MINOR@,@GIG_VERSION_PATCH@,@GIG_VERSION_BUILD@
    FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
    FILEFLAGS VS_FF_DEBUG
#else
    FILEFLAGS 0x0L
#endif
    FILEOS VOS__WINDOWS32
    FILETYPE VFT_APP
    FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Marton Anka"
            VALUE "FileDescription",  "gig - native Frigate streaming client"
            VALUE "FileVersion",      "@GIG_VERSION@"
            VALUE "InternalName",     "gig"
            VALUE "LegalCopyright",   "Copyright (C) 2026 Marton Anka"
            VALUE "OriginalFilename", "gig.exe"
            VALUE "ProductName",      "gig"
            VALUE "ProductVersion",   "@GIG_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
