#include <windows.h>
#include "ui/resource.h"

// Numeric ID 1 makes this the executable's default shell icon, and SDL also
// loads icon resource 1 for the window/taskbar.
1 ICON "gig.ico"

// Settings dialogs (driven by src/ui/settings_dialog.cpp; opened with F2 and on
// first run / unusable config). umbra themes them dark in WM_INITDIALOG. The
// primary dialog holds only what most users touch -- base URL + credentials --
// with everything else behind the Advanced... button (IDD_SETTINGS_ADVANCED).
IDD_SETTINGS DIALOGEX 0, 0, 300, 120
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "gig settings"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Frigate URL:",         IDC_STATIC,        8,  14,  74, 10
    EDITTEXT                                IDC_BASE,         86,  12, 206, 12, ES_AUTOHSCROLL
    LTEXT           "User:",                IDC_STATIC,        8,  31,  74, 10
    EDITTEXT                                IDC_USER,         86,  29, 206, 12, ES_AUTOHSCROLL
    LTEXT           "Password:",            IDC_STATIC,        8,  48,  74, 10
    EDITTEXT                                IDC_PASSWORD,     86,  46, 206, 12, ES_AUTOHSCROLL | ES_PASSWORD
    LTEXT           "",                     IDC_STATUS,        8,  68, 284, 20
    PUSHBUTTON      "Advanced...",          IDC_ADVANCED,      8,  98,  64, 14
    DEFPUSHBUTTON   "OK",                   IDOK,            190,  98,  48, 14
    PUSHBUTTON      "Cancel",               IDCANCEL,        244,  98,  48, 14
END

IDD_SETTINGS_ADVANCED DIALOGEX 0, 0, 300, 275
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Advanced settings"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "TLS / security",       IDC_STATIC,        8,   8, 280, 10
    LTEXT           "CA file:",             IDC_STATIC,        8,  24,  74, 10
    EDITTEXT                                IDC_CA,           86,  22, 160, 12, ES_AUTOHSCROLL
    PUSHBUTTON      "...",                  IDC_BROWSE_CA,   250,  22,  42, 12
    LTEXT           "Client cert:",         IDC_STATIC,        8,  41,  74, 10
    EDITTEXT                                IDC_CERT,         86,  39, 160, 12, ES_AUTOHSCROLL
    PUSHBUTTON      "...",                  IDC_BROWSE_CERT, 250,  39,  42, 12
    LTEXT           "Client key:",          IDC_STATIC,        8,  58,  74, 10
    EDITTEXT                                IDC_KEY,          86,  56, 160, 12, ES_AUTOHSCROLL
    PUSHBUTTON      "...",                  IDC_BROWSE_KEY,  250,  56,  42, 12
    LTEXT           "Leave CA / cert / key blank to use the Windows certificate store.", IDC_STATIC, 8, 73, 284, 9
    CONTROL         "Skip server certificate verification (insecure; disables pinning)", IDC_INSECURE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 8, 85, 284, 10
    LTEXT           "Tuning",               IDC_STATIC,        8, 103, 280, 10
    LTEXT           "Login refresh (s):",   IDC_STATIC,        8, 119,  74, 10
    EDITTEXT                                IDC_LOGIN_REFRESH,86, 117,  50, 12, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Poll interval (s):",   IDC_STATIC,        8, 136,  74, 10
    EDITTEXT                                IDC_POLL,         86, 134,  50, 12, ES_AUTOHSCROLL | ES_NUMBER
    CONTROL         "Force software decode", IDC_SOFTWARE,    "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  86, 151, 206, 10
    CONTROL         "Show diagnostics overlay", IDC_OVERLAY,  "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  86, 165, 206, 10
    LTEXT           "Camera labels:",       IDC_STATIC,        8, 181,  74, 10
    COMBOBOX                                IDC_LABELMODE,    86, 179, 120, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Advanced connection",  IDC_STATIC,        8, 200, 280, 10
    LTEXT           "Single stream URL:",   IDC_STATIC,        8, 216,  74, 10
    EDITTEXT                                IDC_URL,          86, 214, 206, 12, ES_AUTOHSCROLL
    LTEXT           "Stream template:",     IDC_STATIC,        8, 233,  74, 10
    EDITTEXT                                IDC_STREAM_URL,   86, 231, 206, 12, ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK",                   IDOK,            190, 255,  48, 14
    PUSHBUTTON      "Cancel",               IDCANCEL,        244, 255,  48, 14
END

// Application manifest (Common Controls v6 for umbra theming + supportedOS).
// The linker's auto-generated manifest is disabled (/MANIFEST:NO in CMake) so
// this is the sole manifest. RT_MANIFEST id 1 is the default process manifest;
// it doesn't collide with the icon (different resource type).
CREATEPROCESS_MANIFEST_RESOURCE_ID RT_MANIFEST "gig.manifest"

// VS_VERSION_INFO is generated from resources/version.rc.in (CMake substitutes the
// version, default 0.0.0.0, from -DGIG_VERSION) and compiled as a separate .rc --
// see CMakeLists.txt. Keeping it out of here means the version is tag-driven and
// this file stays free of build-time tokens.
