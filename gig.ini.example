# gig.ini -- copy this next to gig.exe (as "gig.ini") and edit.
# All keys are optional; command-line flags override these. Lines starting with
# '#' or ';' are comments. '[section]' headers are allowed but ignored.

# Frigate control-plane base URL (enables multi-camera discovery).
base = https://frigate.lan/security

# Single stream URL instead of discovery (used only when base is empty).
# url = https://frigate.lan/security/api/go2rtc/api/stream.ts?src=frontgate

# Override the discovered per-camera stream URL template.
# stream-url = {base}/api/go2rtc/api/stream.ts?src={name}

# --- TLS auth ---
# With NO ca/cert/key set, the Windows certificate store is used (store CA + CNG
# client cert; pops a consent prompt). Set these to use PEM files instead.
# ca   = C:\Users\Marton\Desktop\winuty\gig\myca.pem
# cert = C:\Users\Marton\Desktop\winuty\gig\marton@mars11.crt
# key  = C:\Users\Marton\Desktop\winuty\gig\marton@mars11.key

# Skip server-certificate verification (testing only).
# insecure = false

# --- decode / UI ---
# Force software decode (skip D3D11VA hardware decode).
# software = false

# Show the diagnostics overlay tile.
# overlay = true

# Health poll interval, in seconds.
# poll-interval = 5

# Per-connection read timeout, in microseconds.
# rw-timeout-us = 10000000
