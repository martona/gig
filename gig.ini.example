# gig.ini -- copy this next to gig.exe (as "gig.ini") and edit. This is the only
# way to configure gig (there are no command-line options). All keys are optional.
# Lines starting with '#' or ';' are comments. '[section]' headers are ignored.

# Frigate control-plane base URL
base = https://frigate.lan/

# Single stream URL instead of discovery (used only when base is empty).
# url = https://frigate.lan/api/go2rtc/api/stream.ts?src=frontgate

# Override the discovered per-camera stream URL template.
# stream-url = {base}/api/go2rtc/api/stream.ts?src={name}

# --- TLS auth ---
# With NO ca/cert/key set, the Windows certificate store is used (store CA + CNG
# client cert; pops a consent prompt). Set these to use PEM files instead.
# ca   = myca.pem
# cert = marton@mars11.crt
# key  = marton@mars11.key

# --- Frigate username/password auth ---
# With user+password set, gig POSTs {base}/api/login at startup, carries the
# returned frigate_token cookie on every request (API + video), and re-logs-in
# every login-refresh seconds to keep the token fresh. Requires 'base'.
# Independent of TLS auth above. To run plain TLS with NO client certificate
# (and no cert picker/consent prompts), set 'ca' alone alongside user/password.
# user = viewer
# password = secret
# login-refresh = 600

# Skip server-certificate verification (testing only).
# insecure = false

# --- decode / UI ---
# Force software decode (skip D3D11VA hardware decode).
# software = false

# Show the diagnostics overlay tile.
# overlay = true

# Health poll interval, in seconds.
# poll-interval = 5

# Per-connection read timeout, in microseconds.
# rw-timeout-us = 10000000
